{
  "name": "predictarena",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:contracts": "HOME=$PWD/.home XDG_CACHE_HOME=$PWD/.cache HARDHAT_DISABLE_TELEMETRY_PROMPT=true HARDHAT_HIDE_SOLIDITY_SURVEY_MESSAGE=true hardhat test",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "viem": "^2.30.0",
    "zod": "^3.25.6"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "hardhat": "^2.24.1",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
